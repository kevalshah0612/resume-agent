# Provider mode:
# 1 = NVIDIA API model selected in the GUI
# 2 = Direct Anthropic Claude
PROVIDER_MODE=1

# NVIDIA
# One or both accounts may be configured. Distinct keys are load-balanced.
NVIDIA_API_KEY_1=your_first_key
NVIDIA_API_KEY_2=your_second_key
# Legacy single-key fallback (omit when it duplicates key 1 or key 2).
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_THINKING=true
NVIDIA_MEDIUM_EFFORT=false
NVIDIA_TEMPERATURE=1.0
NVIDIA_TOP_P=0.95
NVIDIA_SEED=42
NVIDIA_STREAM=false
NVIDIA_REASONING_BUDGET=32768
RESPONSE_MAX_TOKENS=65536
NVIDIA_MAX_ATTEMPTS=5
NVIDIA_MAX_CONCURRENT_REQUESTS=10
NVIDIA_MAX_CONCURRENT_REQUESTS_PER_ACCOUNT=5
# 0 disables the HTTP timeout. A stalled non-streaming request may then wait indefinitely.
NVIDIA_TIMEOUT_SECONDS=0
NVIDIA_GUIDED_JSON=true
NVIDIA_VALIDATION_PASS=false
NVIDIA_VALIDATOR_SEED=43

# Keep Claude configured for PROVIDER_MODE=2. Automatic NVIDIA fallback is off.
FALLBACK_TO_ANTHROPIC=false
ANTHROPIC_API_KEY=your_key
