{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "story_mapper_output_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "resume_mode", "role", "level", "keyword_plan", "experience_plan", "project_plan", "skills_keyword_ids", "des_questions", "coverage"],
  "properties": {
    "status": {"type": "string", "enum": ["ready", "des_required"]},
    "resume_mode": {"type": "string", "enum": ["entry_swe", "mid_swe", "entry_ai_ml"]},
    "role": {"type": "string"},
    "level": {"type": "string", "enum": ["entry", "mid", "out_of_scope", "unclear"]},
    "keyword_plan": {"type": "array", "items": {"$ref": "#/$defs/keyword"}},
    "experience_plan": {"type": "array", "items": {"$ref": "#/$defs/experience"}},
    "project_plan": {"type": "array", "items": {"$ref": "#/$defs/project"}},
    "skills_keyword_ids": {"$ref": "#/$defs/ids"},
    "des_questions": {"type": "array", "items": {"$ref": "#/$defs/des"}},
    "coverage": {"$ref": "#/$defs/coverage"}
  },
  "$defs": {
    "ids": {"type": "array", "items": {"type": "string", "pattern": "^K[0-9]{3}$"}, "uniqueItems": true},
    "keyword": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "keyword", "bucket", "requirement_status", "category", "priority", "evidence_state", "confidence", "story_id", "evidence", "target"],
      "properties": {
        "id": {"type": "string", "pattern": "^K[0-9]{3}$"}, "keyword": {"type": "string"},
        "bucket": {"type": "integer", "minimum": 2, "maximum": 5},
        "requirement_status": {"type": "string", "enum": ["required", "core", "preferred"]},
        "category": {"type": "string", "enum": ["tech", "nontech"]}, "priority": {"type": "number"},
        "evidence_state": {"type": "string", "enum": ["direct", "supported_equivalent", "candidate_approved", "confirmation_required", "missing", "not_selected"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "story_id": {"type": "string"},
        "evidence": {"type": "string"}, "target": {"type": "string", "enum": ["experience", "project", "skills", "missing"]}
      }
    },
    "slot": {
      "type": "object", "additionalProperties": false, "required": ["slot", "story_id", "keyword_ids"],
      "properties": {"slot": {"type": "integer", "minimum": 1}, "story_id": {"type": "string"}, "keyword_ids": {"$ref": "#/$defs/ids"}}
    },
    "experience": {
      "type": "object", "additionalProperties": false, "required": ["role_id", "slots"],
      "properties": {"role_id": {"type": "string"}, "slots": {"type": "array", "items": {"$ref": "#/$defs/slot"}}}
    },
    "project": {
      "type": "object", "additionalProperties": false, "required": ["rank", "story_id", "keyword_ids", "score"],
      "properties": {"rank": {"type": "integer", "minimum": 1}, "story_id": {"type": "string"}, "keyword_ids": {"$ref": "#/$defs/ids"}, "score": {"type": "number"}}
    },
    "des": {
      "type": "object", "additionalProperties": false, "required": ["des_id", "keyword_id", "keyword", "bucket", "closest_story_id", "proposed_use", "question"],
      "properties": {"des_id": {"type": "integer", "minimum": 1}, "keyword_id": {"type": "string"}, "keyword": {"type": "string"}, "bucket": {"type": "integer", "minimum": 2, "maximum": 5}, "closest_story_id": {"type": "string"}, "proposed_use": {"type": "string"}, "question": {"type": "string"}}
    },
    "coverage": {
      "type": "object", "additionalProperties": false,
      "required": ["total_keywords", "direct", "supported_equivalent", "candidate_approved", "confirmation_required", "missing", "not_selected"],
      "properties": {"total_keywords": {"type": "integer", "minimum": 0}, "direct": {"type": "integer", "minimum": 0}, "supported_equivalent": {"type": "integer", "minimum": 0}, "candidate_approved": {"type": "integer", "minimum": 0}, "confirmation_required": {"type": "integer", "minimum": 0}, "missing": {"type": "integer", "minimum": 0}, "not_selected": {"type": "integer", "minimum": 0}}
    }
  }
}
