{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "validator_repair_output_v1",
  "type": "object", "additionalProperties": false,
  "required": ["status", "summary", "experience", "projects", "technical_skills", "coverage", "des_questions", "repairs"],
  "properties": {
    "status": {"type": "string", "enum": ["valid", "repaired"]},
    "summary": {"type": "string"},
    "experience": {"type": "array", "items": {"$ref": "#/$defs/role"}},
    "projects": {"type": "array", "items": {"$ref": "#/$defs/project"}},
    "technical_skills": {"type": "array", "items": {"$ref": "#/$defs/skill"}},
    "coverage": {"$ref": "#/$defs/coverage"},
    "des_questions": {"type": "array", "maxItems": 0, "items": {"$ref": "#/$defs/des"}},
    "repairs": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "bullet": {"type": "object", "additionalProperties": false, "required": ["story_id", "text", "keyword_ids", "word_count"], "properties": {"story_id": {"type": "string"}, "text": {"type": "string"}, "keyword_ids": {"$ref": "#/$defs/ids"}, "word_count": {"type": "integer", "minimum": 0}}},
    "role": {"type": "object", "additionalProperties": false, "required": ["role_id", "title", "company", "location", "dates", "bullets"], "properties": {"role_id": {"type": "string"}, "title": {"type": "string"}, "company": {"type": "string"}, "location": {"type": "string"}, "dates": {"type": "string"}, "employment_note": {"type": "string"}, "bullets": {"type": "array", "items": {"$ref": "#/$defs/bullet"}}}},
    "project": {"type": "object", "additionalProperties": false, "required": ["story_id", "name", "bullets"], "properties": {"story_id": {"type": "string"}, "name": {"type": "string"}, "bullets": {"type": "array", "items": {"$ref": "#/$defs/bullet"}}}},
    "skill": {"type": "object", "additionalProperties": false, "required": ["category", "keywords"], "properties": {"category": {"type": "string"}, "keywords": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}}},
    "coverage": {"type": "object", "additionalProperties": false, "required": ["placed_keyword_ids", "skills_only_keyword_ids", "missing_keyword_ids", "not_selected_keyword_ids"], "properties": {"placed_keyword_ids": {"$ref": "#/$defs/ids"}, "skills_only_keyword_ids": {"$ref": "#/$defs/ids"}, "missing_keyword_ids": {"$ref": "#/$defs/ids"}, "not_selected_keyword_ids": {"$ref": "#/$defs/ids"}}},
    "des": {"type": "object", "additionalProperties": false, "required": ["des_id", "keyword_id", "keyword", "closest_story_id", "question"], "properties": {"des_id": {"type": "integer", "minimum": 1}, "keyword_id": {"type": "string"}, "keyword": {"type": "string"}, "closest_story_id": {"type": "string"}, "question": {"type": "string"}}}
  }
}
