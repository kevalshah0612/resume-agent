{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project_writer_output_v1",
  "type": "object", "additionalProperties": false,
  "required": ["projects", "used_keyword_ids", "unused_keyword_ids"],
  "properties": {"projects": {"type": "array", "items": {"$ref": "#/$defs/project"}}, "used_keyword_ids": {"$ref": "#/$defs/ids"}, "unused_keyword_ids": {"$ref": "#/$defs/ids"}},
  "$defs": {
    "ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "bullet": {"type": "object", "additionalProperties": false, "required": ["slot", "text", "keyword_ids", "word_count"], "properties": {"slot": {"type": "integer", "minimum": 1}, "text": {"type": "string"}, "keyword_ids": {"$ref": "#/$defs/ids"}, "word_count": {"type": "integer", "minimum": 0}}},
    "project": {"type": "object", "additionalProperties": false, "required": ["rank", "story_id", "name", "bullets"], "properties": {"rank": {"type": "integer", "minimum": 1}, "story_id": {"type": "string"}, "name": {"type": "string"}, "bullets": {"type": "array", "items": {"$ref": "#/$defs/bullet"}}}}
  }
}
