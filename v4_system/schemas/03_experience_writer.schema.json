{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "experience_writer_output_v1",
  "type": "object", "additionalProperties": false,
  "required": ["experience", "used_keyword_ids", "unused_keyword_ids"],
  "properties": {
    "experience": {"type": "array", "items": {"$ref": "#/$defs/role"}},
    "used_keyword_ids": {"$ref": "#/$defs/ids"}, "unused_keyword_ids": {"$ref": "#/$defs/ids"}
  },
  "$defs": {
    "ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "bullet": {"type": "object", "additionalProperties": false, "required": ["slot", "story_id", "text", "keyword_ids", "word_count"], "properties": {"slot": {"type": "integer", "minimum": 1}, "story_id": {"type": "string"}, "text": {"type": "string"}, "keyword_ids": {"$ref": "#/$defs/ids"}, "word_count": {"type": "integer", "minimum": 0}}},
    "role": {"type": "object", "additionalProperties": false, "required": ["role_id", "title", "company", "location", "dates", "bullets"], "properties": {"role_id": {"type": "string"}, "title": {"type": "string"}, "company": {"type": "string"}, "location": {"type": "string"}, "dates": {"type": "string"}, "employment_note": {"type": "string"}, "bullets": {"type": "array", "items": {"$ref": "#/$defs/bullet"}}}}
  }
}
